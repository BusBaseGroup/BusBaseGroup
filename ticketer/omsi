<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>BusBase OMSI ETM</title>
<style>
:root{--blue:#00006f;--blue2:#0712a4;--blue3:#000044;--screen:#d5dbea;--panel:#eef1f8;--line:#8c96ad;--orange:#efa637;--red:#bf0b1f;--green:#168032;--black:#050505;--amber:#d98b00}*{box-sizing:border-box}html,body{height:100%}body{margin:0;background:#161616;display:grid;place-items:center;font-family:Arial,Helvetica,sans-serif;color:#050505;padding:10px;user-select:none}.etm{width:480px;max-width:100%;background:#050505;border:16px solid #050505;border-radius:6px;box-shadow:0 22px 65px rgba(0,0,0,.78),inset 0 0 0 2px #202020}.screen{height:760px;background:var(--screen);border:3px solid #000;display:grid;grid-template-rows:84px minmax(0,1fr)31px;overflow:hidden}.screen.pre{grid-template-rows:minmax(0,1fr)}.screen.pre .top,.screen.pre .status{display:none}.top{background:#070b21;color:#fff;border-bottom:2px solid #000;text-align:center;font-weight:900}.line{height:28px;display:grid;grid-template-columns:28px 1fr 28px;align-items:center;border-bottom:1px solid #3d4598;background:var(--blue);font-size:12px}.line.stop{background:#101f8f;font-size:11px}.line.dest{background:var(--blue3)}.line div{padding:0 4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.arrow{background:#000080;border:1px solid #5864d4;color:#fff;height:100%;font-weight:900}.work{padding:3px;overflow:hidden}.page{display:none;height:100%;overflow:auto}.page.active{display:block}.head{height:23px;background:var(--blue3);color:white;border:1px solid #000;border-bottom-color:#4e5abe;font-size:10px;font-weight:900;text-transform:uppercase;display:flex;align-items:center;justify-content:space-between;padding:3px 5px}.panel{background:var(--panel);border:1px solid var(--line);margin-top:3px;padding:5px}.row{display:grid;grid-template-columns:1fr auto;gap:5px;min-height:28px;background:#eef1f8;border:1px solid #9ba3b4;margin-top:2px;padding:5px;font-size:11px;font-weight:900;align-items:center}.row.selected{background:var(--orange)}button{background:var(--blue);color:#fff;border:1px solid #5e68d3;min-height:26px;padding:3px 5px;font-size:9px;font-weight:900;text-transform:uppercase;border-radius:0}button:active{filter:brightness(.85)}button.red{background:var(--red);border-color:#7d0010}button.green{background:var(--green);border-color:#074d1d}button.orange{background:var(--orange);color:#050505;border-color:#8c6106}button.white{background:#e3e8f2;color:var(--blue3);border-color:#737d96}.grid{display:grid;grid-template-columns:repeat(2,1fr);gap:3px;margin-top:3px}.grid3{display:grid;grid-template-columns:repeat(3,1fr);gap:3px;margin-top:3px}.bottom{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;margin-top:3px}.ticket{min-height:72px;background:#d9e0ee!important;color:#000;border:1px solid #343a4a;position:relative;text-align:center;display:grid;grid-template-rows:16px 18px 1fr 15px;align-items:center;text-transform:none;font-size:9px}.ticket .qty{position:absolute;top:2px;left:2px;width:21px;height:16px;background:#fff;border:1px solid #333;line-height:14px;font-weight:900}.ticket strong{padding:0 22px;font-size:9px}.ticket .price{font-size:12px;font-weight:900}.ticket:after{content:'−        +';border-top:1px solid #6f7685;background:#c2c9d6;margin-left:-3px;width:calc(100% + 6px);letter-spacing:15px;font-size:10px}input,select,textarea{width:100%;height:26px;border:1px solid #444f68;border-radius:0;padding:4px;font-size:11px;font-family:Arial,Helvetica,sans-serif;background:#fff}textarea{height:70px;resize:none}label{font-size:9px;font-weight:900}.status{background:var(--blue3);color:white;display:grid;grid-template-columns:38px 44px 48px 50px 52px 1fr;gap:1px;padding:1px;font-size:8px;text-align:center}.status div{background:var(--blue);border:1px solid #3741ac;padding:4px 1px;font-weight:900}.ok{color:#35e64c}.bad{color:#ff3b3b}.warn{color:#ffd33d}.timebox{border:2px solid #111;background:var(--green);color:#fff;padding:7px;font-weight:900;font-size:13px;text-align:center;margin-top:3px}.timebox.ontime{background:var(--green)}.timebox.slight{background:var(--amber)}.timebox.badtime{background:var(--red)}.last{background:#111827;color:#fff;border:1px solid #000;padding:6px;margin-top:3px;font-size:11px;font-weight:900}.info{display:grid;grid-template-columns:1fr 1fr;gap:3px}.info div{background:#fff;border:1px solid #8c96ad;padding:5px;font-weight:900;font-size:10px}.paper{font-family:'Courier New',monospace;background:#fffef0;border:1px solid #111;padding:8px;white-space:pre-wrap;display:none;max-height:120px;overflow:auto;font-size:9px}.modal{position:fixed;inset:0;background:rgba(0,0,0,.55);display:none;place-items:center;padding:20px;z-index:10}.modal.show{display:grid}.popup{width:min(380px,94vw);background:#f6f7fa;border:3px solid #10184c}.popup .body{padding:10px;font-size:12px;line-height:1.35}.hidden{display:none!important}@media(max-width:520px){body{padding:0;background:#050505}.etm{width:100%;border-width:8px;border-radius:0}.screen{height:100vh}}
</style>
</head>
<body>
<div class="etm"><div id="screen" class="screen pre">
  <div class="top">
    <div class="line"><button class="arrow" onclick="prevStop()">‹</button><div id="stageLine" onclick="showStopList()">FARE STAGE</div><button class="arrow" onclick="nextStop()">›</button></div>
    <div class="line stop"><button class="arrow" onclick="prevStop()">‹</button><div id="stopLine" onclick="showStopList()">CURRENT STOP</div><button class="arrow" onclick="nextStop()">›</button></div>
    <div class="line dest"><button class="arrow" onclick="prevDest()">‹</button><div id="destLine">DESTINATION</div><button class="arrow" onclick="nextDest()">›</button></div>
  </div>
  <main class="work">
    <section id="login" class="page active">
      <div class="head">Driver Login <span>OMSI MODE</span></div>
      <div class="panel">
        <p><b>BusBase OMSI ETM</b></p>
        <p>Separate OMSI version with live running, next stop and last stop status.</p>
        <label>Driver number</label><input id="driverNo" value="1234" inputmode="numeric">
        <label>PIN</label><input id="pin" value="1234" inputmode="numeric" type="password">
        <div class="grid3"><button onclick="num('1')">1</button><button onclick="num('2')">2</button><button onclick="num('3')">3</button><button onclick="num('4')">4</button><button onclick="num('5')">5</button><button onclick="num('6')">6</button><button onclick="num('7')">7</button><button onclick="num('8')">8</button><button onclick="num('9')">9</button><button onclick="clearPin()">Clear</button><button onclick="num('0')">0</button><button class="green" onclick="login()">Accept</button></div>
      </div>
    </section>

    <section id="vehicle" class="page">
      <div class="head">Vehicle Selection <span id="driverName">Driver</span></div>
      <div id="vehicleList" class="panel"></div>
      <div class="bottom"><button class="red" onclick="logout()">Back</button><button class="white">Details</button><button class="white">Depot</button><button class="green" onclick="go('trip')">Accept</button></div>
    </section>

    <section id="trip" class="page">
      <div class="head">Start Trip <span>Running Board</span></div>
      <div class="panel">
        <label>Route</label><select id="routeSelect" onchange="selectRoute()"></select>
        <label>Trip start time</label><input id="startTime" type="time">
        <label>Mode</label><select id="mode"><option value="manual">Manual / test</option><option value="firestore">OMSI bridge / Firebase</option></select>
        <div class="info"><div>Route<br><span id="previewRoute">--</span></div><div>Stops<br><span id="previewStops">--</span></div></div>
      </div>
      <div class="bottom"><button class="red" onclick="go('vehicle')">Back</button><button onclick="go('bridge')">Bridge</button><button onclick="go('options')">Options</button><button class="green" onclick="startTrip()">Accept</button></div>
    </section>

    <section id="ticketPage" class="page">
      <div class="head">Ticket Issue <button onclick="go('options')">Options</button></div>
      <div class="timebox" id="runningBox">Running: --</div>
      <div class="last" id="lastStopBox">Last stop: waiting</div>
      <div class="info"><div>Current<br><span id="currentStopBox">--</span></div><div>Next<br><span id="nextStopBox">--</span></div></div>
      <div class="grid" id="tickets"></div>
      <div class="info"><div>Trip<br><span id="tripTotal">£0.00 / 0 pax</span></div><div>Duty<br><span id="dutyTotal">£0.00 / 0 pax</span></div></div>
      <div id="ticketPaper" class="paper"></div>
      <div class="bottom"><button onclick="prevStop()">Prev Stop</button><button onclick="nextStop()">Next Stop</button><button onclick="go('bridge')">OMSI Data</button><button class="red" onclick="endTrip()">End Trip</button></div>
    </section>

    <section id="bridge" class="page">
      <div class="head">OMSI Bridge Data <span id="bridgeStatus">Manual</span></div>
      <div class="panel">
        <p><b>Test data sender</b> - this writes the same shape your OMSI bridge/plugin should send.</p>
        <label>Running seconds</label><input id="simRunning" type="number" value="0">
        <label>Current stop index</label><input id="simIndex" type="number" value="0">
        <label>Door status</label><select id="simDoors"><option>Closed</option><option>Open</option></select>
        <div class="grid"><button onclick="sendSimData()">Send to Firebase</button><button onclick="fakeMove()">Move + Late</button></div>
      </div>
      <div class="panel">
        <p><b>Expected Firebase path:</b></p>
        <p><code>omsiLive/currentBus</code></p>
        <textarea readonly id="jsonExample"></textarea>
      </div>
      <div class="bottom"><button class="red" onclick="go('trip')">Back</button><button onclick="listenFirebase()">Listen</button><button onclick="manualApply()">Apply Manual</button><button class="green" onclick="go('ticketPage')">Tickets</button></div>
    </section>

    <section id="options" class="page">
      <div class="head">Options Menu <span>OMSI ETM</span></div>
      <div class="panel">
        <div class="row" onclick="go('ticketPage')"><span>Ticket Selling</span><b>›</b></div>
        <div class="row" onclick="showStopList()"><span>Fare Stages / Stops</span><b>›</b></div>
        <div class="row" onclick="go('bridge')"><span>OMSI Live Data</span><b>›</b></div>
        <div class="row" onclick="showWaybill()"><span>Duty Summary</span><b>›</b></div>
        <div class="row" onclick="resetTrip()"><span>Reset Trip Totals</span><b>›</b></div>
      </div>
      <div class="bottom"><button class="red" onclick="go('ticketPage')">Back</button><button class="white">Print</button><button class="orange" onclick="resetDuty()">Reset Duty</button><button class="green" onclick="go('ticketPage')">Accept</button></div>
    </section>
  </main>
  <div class="status"><div>GPS <span class="ok">✓</span></div><div>GPRS <span id="gprs" class="warn">●</span></div><div>OMSI <span id="omsiIcon" class="warn">●</span></div><div>MSG <span class="ok">0</span></div><div>PRN <span class="ok">✓</span></div><div id="clock">--:--</div></div>
</div></div>
<div id="modal" class="modal"><div class="popup"><div class="head">Information <button onclick="closeModal()">X</button></div><div id="modalBody" class="body"></div><div class="bottom"><button class="red" onclick="closeModal()">Back</button><button class="green" onclick="closeModal()">Accept</button></div></div></div>

<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.5/firebase-app.js";
import { getFirestore, doc, getDoc, setDoc, onSnapshot, serverTimestamp } from "https://www.gstatic.com/firebasejs/10.12.5/firebase-firestore.js";

const firebaseConfig={apiKey:"AIzaSyBBCqx9D1r5U9mWJYKEY_dtCdyk132xGog",authDomain:"busbase-ticketer-v2.firebaseapp.com",projectId:"busbase-ticketer-v2",storageBucket:"busbase-ticketer-v2.firebasestorage.app",messagingSenderId:"807388978236",appId:"1:807388978236:web:5ccf7c8193d81498377739"};
const app=initializeApp(firebaseConfig);const db=getFirestore(app);window.db=db;window.fs={doc,getDoc,setDoc,onSnapshot,serverTimestamp};
</script>
<script>
const $=id=>document.getElementById(id);let currentPage='login',driver={id:'1234',name:'Driver'},selectedVehicle='OMSI Bus',route=null,stopIndex=0,destIndex=1,unsub=null,trip={cash:0,pax:0},duty=JSON.parse(localStorage.getItem('omsiDuty')||'{"cash":0,"pax":0}');
const vehicles=['OMSI Bus','Lynx 365','Lynx 658','ADL Enviro200','ADL Enviro400'];
const routes=[{id:'34',name:'34 King’s Lynn - Hunstanton',destination:'Hunstanton',stops:[['King’s Lynn Bus Station','09:00',0],['Gaywood Clock','09:08',260],['South Wootton','09:16',430],['Dersingham','09:29',720],['Snettisham','09:38',950],['Heacham','09:47',1160],['Hunstanton Bus Station','09:58',1380]],fares:[['King’s Lynn','£2.00',2],['Dersingham','£3.10',3.1],['Snettisham','£3.10',3.1],['Heacham','£4.10',4.1],['Hunstanton','£4.10',4.1]]},{id:'36',name:'36 The Loop',destination:'Wells-next-the-Sea',stops:[['Fakenham Oak Street','10:00',0],['Holt Road','10:06',180],['Walsingham','10:17',510],['Stiffkey','10:31',900],['Wells-next-the-Sea','10:42',1260]],fares:[['Fakenham','£2.00',2],['Walsingham','£3.10',3.1],['Stiffkey','£4.10',4.1],['Wells','£4.10',4.1]]},{id:'44',name:'44 The Loop',destination:'Fakenham',stops:[['Wells-next-the-Sea','11:00',0],['Stiffkey','11:12',260],['Walsingham','11:27',610],['Holt Road','11:38',900],['Fakenham Oak Street','11:46',1120]],fares:[['Wells','£2.00',2],['Walsingham','£3.10',3.1],['Fakenham','£4.10',4.1]]}];
function go(id){$(currentPage)?.classList.remove('active');currentPage=id;$(id).classList.add('active');$('screen').classList.toggle('pre',id==='login'||id==='vehicle'||id==='trip');updateAll()}window.go=go;
function login(){driver={id:$('driverNo').value||'1234',name:'Driver '+($('driverNo').value||'1234')};$('driverName').textContent=driver.name;renderVehicles();go('vehicle')}window.login=login;
function logout(){trip={cash:0,pax:0};go('login')}window.logout=logout;function num(n){$('pin').value+=n}window.num=num;function clearPin(){$('pin').value=''}window.clearPin=clearPin;
function renderVehicles(){$('vehicleList').innerHTML=vehicles.map((v,i)=>`<div class="row ${i===0?'selected':''}" onclick="selectedVehicle='${v}';renderVehicles()"><span>${v}</span><small>${i===0?'selected':''}</small></div>`).join('')}window.renderVehicles=renderVehicles;
function initRoutes(){$('routeSelect').innerHTML=routes.map((r,i)=>`<option value="${i}">${r.name}</option>`).join('');selectRoute();const d=new Date();$('startTime').value=String(d.getHours()).padStart(2,'0')+':'+String(d.getMinutes()).padStart(2,'0')}function selectRoute(){route=routes[+$('routeSelect').value||0];stopIndex=0;destIndex=route.stops.length-1;$('previewRoute').textContent=route.name;$('previewStops').textContent=route.stops.length;renderTickets();updateAll();updateJsonExample()}window.selectRoute=selectRoute;
function startTrip(){route=routes[+$('routeSelect').value||0];stopIndex=0;destIndex=route.stops.length-1;trip={cash:0,pax:0};if($('mode').value==='firestore')listenFirebase();go('ticketPage')}window.startTrip=startTrip;
function renderTickets(){if(!route)return;$('tickets').innerHTML=route.fares.map((f,i)=>`<button class="ticket" onclick="sellTicket(${i})"><span class="qty">0</span><strong>${f[0]}</strong><span class="price">${f[1]}</span><span>Adult Single</span></button>`).join('')}function sellTicket(i){const fare=route.fares[i];trip.cash+=fare[2];trip.pax++;duty.cash+=fare[2];duty.pax++;localStorage.setItem('omsiDuty',JSON.stringify(duty));$('ticketPaper').style.display='block';$('ticketPaper').textContent=`BUSBASE OMSI ETM\nRoute ${route.id} to ${route.destination}\nFrom ${route.stops[stopIndex][0]}\nTo ${fare[0]}\nFare ${fare[1]}\n${new Date().toLocaleString('en-GB')}`;updateTotals()}window.sellTicket=sellTicket;
function updateTotals(){$('tripTotal').textContent=`£${trip.cash.toFixed(2)} / ${trip.pax} pax`;$('dutyTotal').textContent=`£${duty.cash.toFixed(2)} / ${duty.pax} pax`}function resetTrip(){trip={cash:0,pax:0};updateTotals();modal('Trip totals reset.')}window.resetTrip=resetTrip;function resetDuty(){duty={cash:0,pax:0};localStorage.setItem('omsiDuty',JSON.stringify(duty));updateTotals();modal('Duty totals reset.')}window.resetDuty=resetDuty;
function prevStop(){if(!route)return;stopIndex=Math.max(0,stopIndex-1);destIndex=Math.max(stopIndex+1,destIndex);manualApply()}window.prevStop=prevStop;function nextStop(){if(!route)return;const old=stopIndex;stopIndex=Math.min(route.stops.length-1,stopIndex+1);destIndex=Math.max(stopIndex+1,destIndex);setLastStop(old,0);manualApply()}window.nextStop=nextStop;function prevDest(){destIndex=Math.max(stopIndex+1,destIndex-1);updateAll()}window.prevDest=prevDest;function nextDest(){destIndex=Math.min(route.stops.length-1,destIndex+1);updateAll()}window.nextDest=nextDest;
function formatRun(sec){sec=Number(sec||0);if(Math.abs(sec)<=30)return'On time';const mins=Math.round(Math.abs(sec)/60);return `${mins} min${mins===1?'':'s'} ${sec<0?'early':'late'}`}function runClass(sec){sec=Number(sec||0);if(Math.abs(sec)<=30)return'ontime';if(Math.abs(sec)<=60)return'slight';return'badtime'}function setRunning(sec){$('runningBox').className='timebox '+runClass(sec);$('runningBox').textContent='Running: '+formatRun(sec)}function setLastStop(index,sec){if(!route||index<0)return;localStorage.setItem('omsiLastStop',JSON.stringify({name:route.stops[index][0],text:formatRun(sec),sec}))}
function updateAll(){if(!route)return;const current=route.stops[stopIndex]||route.stops[0],next=route.stops[stopIndex+1]||['End of route'],dest=route.stops[destIndex]||route.stops.at(-1);$('stageLine').textContent=current[0];$('stopLine').textContent=current[0];$('destLine').textContent=dest[0]||route.destination;$('currentStopBox').textContent=current[0];$('nextStopBox').textContent=next[0];const last=JSON.parse(localStorage.getItem('omsiLastStop')||'null');$('lastStopBox').textContent=last?`Last stop: ${last.name} - ${last.text}`:'Last stop: waiting';updateTotals();updateJsonExample()}window.updateAll=updateAll;
function applyLive(data){if(!route)return;if(data.route){const idx=routes.findIndex(r=>String(r.id)===String(data.route));if(idx>=0){$('routeSelect').value=idx;route=routes[idx]}}let newIndex=Number.isFinite(+data.stopIndex)?+data.stopIndex:route.stops.findIndex(s=>s[0]===data.currentStop);if(newIndex>=0&&newIndex!==stopIndex){setLastStop(stopIndex,Number(data.runningSeconds||0));stopIndex=Math.max(0,Math.min(route.stops.length-1,newIndex))}if(Number.isFinite(+data.destIndex))destIndex=+data.destIndex;setRunning(Number(data.runningSeconds||0));if(data.lastStop?.name){localStorage.setItem('omsiLastStop',JSON.stringify({name:data.lastStop.name,text:data.lastStop.time||formatRun(data.runningSeconds),sec:data.runningSeconds||0}))}$('bridgeStatus').textContent='Live';$('gprs').className='ok';$('omsiIcon').className='ok';$('simIndex').value=stopIndex;updateAll()}
async function listenFirebase(){if(unsub)unsub();try{const ref=window.fs.doc(window.db,'omsiLive','currentBus');unsub=window.fs.onSnapshot(ref,s=>{if(s.exists())applyLive(s.data())});$('bridgeStatus').textContent='Listening';$('gprs').className='ok';$('omsiIcon').className='warn';modal('Listening to Firebase path: omsiLive/currentBus')}catch(e){modal('Firebase listen failed: '+e.message)}}window.listenFirebase=listenFirebase;
async function sendSimData(){if(!route)return;const idx=Math.max(0,Math.min(route.stops.length-1,Number($('simIndex').value||0)));const sec=Number($('simRunning').value||0);const payload={route:route.id,destination:route.destination,stopIndex:idx,currentStop:route.stops[idx][0],nextStop:(route.stops[idx+1]||['End of route'])[0],runningSeconds:sec,runningText:formatRun(sec),lastStop:{name:idx>0?route.stops[idx-1][0]:'None',time:formatRun(sec),status:sec>60?'late':sec<-60?'early':'on-time'},doors:$('simDoors').value,vehicle:selectedVehicle,updatedAt:window.fs.serverTimestamp(),updatedAtMs:Date.now()};try{await window.fs.setDoc(window.fs.doc(window.db,'omsiLive','currentBus'),payload,{merge:true});applyLive(payload)}catch(e){modal('Could not send test data: '+e.message)}}window.sendSimData=sendSimData;
function fakeMove(){$('simIndex').value=Math.min(route.stops.length-1,Number($('simIndex').value||0)+1);$('simRunning').value=Number($('simRunning').value||0)+75;sendSimData()}window.fakeMove=fakeMove;function manualApply(){const idx=Math.max(0,Math.min(route.stops.length-1,Number($('simIndex').value||stopIndex)));stopIndex=idx;setRunning(Number($('simRunning').value||0));updateAll()}window.manualApply=manualApply;
function showStopList(){if(!route)return;modal('<b>Select stop</b>'+route.stops.map((s,i)=>`<div class="row" onclick="stopIndex=${i};closeModal();manualApply()"><span>${s[0]}</span><small>${s[1]}</small></div>`).join(''))}window.showStopList=showStopList;function showWaybill(){modal(`<b>Duty summary</b><br>Driver: ${driver.name}<br>Vehicle: ${selectedVehicle}<br>Route: ${route?.name||'--'}<br>Trip: £${trip.cash.toFixed(2)} / ${trip.pax} pax<br>Duty: £${duty.cash.toFixed(2)} / ${duty.pax} pax`)}window.showWaybill=showWaybill;
function modal(html){$('modalBody').innerHTML=html;$('modal').classList.add('show')}window.modal=modal;function closeModal(){$('modal').classList.remove('show')}window.closeModal=closeModal;function updateJsonExample(){if(!route)return;const idx=Number($('simIndex')?.value||0),sec=Number($('simRunning')?.value||0);$('jsonExample').value=JSON.stringify({route:route.id,destination:route.destination,stopIndex:idx,currentStop:route.stops[idx]?.[0],nextStop:route.stops[idx+1]?.[0]||'End of route',runningSeconds:sec,runningText:formatRun(sec),lastStop:{name:idx>0?route.stops[idx-1][0]:'None',time:formatRun(sec)}},null,2)}
function endTrip(){showWaybill();trip={cash:0,pax:0};updateTotals()}window.endTrip=endTrip;
setInterval(()=>$('clock').textContent=new Date().toLocaleTimeString('en-GB',{hour:'2-digit',minute:'2-digit'}),1000);initRoutes();renderVehicles();setRunning(0);updateTotals();
</script>
</body>
</html>